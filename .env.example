# Flask/Express Configuration
SECRET_KEY=your-secure-random-secret-key-here
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databaseName?retryWrites=true&w=majority
MONGO_DB_NAME=auraFest

# Admin Token
ADMIN_TOKEN=your-admin-token-here

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Booking Configuration
BOOKING_FROM_EMAIL=your-email@gmail.com

# Database Timeout (optional)
DB_TIMEOUT_MS=5000

# SMTP Connection Timeout (optional)
SMTP_CONNECTION_TIMEOUT_MS=10000
